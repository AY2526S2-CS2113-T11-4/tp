@startuml
skinparam maxMessageSize 150
skinparam style strictuml
autonumber

actor Caller
participant "cmd:SearchCommand" as SearchCommand
participant "db:StudentDatabase" as StudentDatabase
participant "student:Student" as Student
participant "m:Module" as Module

Caller -> SearchCommand : execute(db, storage)
activate SearchCommand

SearchCommand -> StudentDatabase : getAllStudents()
activate StudentDatabase
StudentDatabase --> SearchCommand : List<Student>
deactivate StudentDatabase

loop for each student in List<Student>
    SearchCommand -> SearchCommand : isStudentMatch(student)
    activate SearchCommand

    ' Fetch basic attributes for matching
    SearchCommand -> Student : getName(), getCourse(), etc.
    activate Student
    Student --> SearchCommand : field values
    deactivate Student

    ' Module matching logic (only executed if user searched by moduleCode)
    opt if this.moduleCode != null
        SearchCommand -> SearchCommand : getMatchingModulesString(student)
        activate SearchCommand

        SearchCommand -> Student : getModules()
        activate Student
        Student --> SearchCommand : List<Module>
        deactivate Student

        loop for each m in List<Module>
            SearchCommand -> Module : getCode(), getGrade()
            activate Module
            Module --> SearchCommand : code, grade
            deactivate Module
        end

        SearchCommand --> SearchCommand : matched modules string (or null)
        deactivate SearchCommand
    end

    SearchCommand --> SearchCommand : boolean (isMatch)
    deactivate SearchCommand

    ' Formatting logic (only executed if student is a valid match)
    opt if isMatch == true
        SearchCommand -> SearchCommand : formatStudentDetails(index, student)
        activate SearchCommand
        SearchCommand --> SearchCommand : formatted string appended to resultBuilder
        deactivate SearchCommand
    end
end

create "result:CommandResult" as CommandResult
SearchCommand -> CommandResult : new CommandResult(finalString)

SearchCommand --> Caller : result
deactivate SearchCommand
@enduml
